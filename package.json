{
  "name": "vantis-mail",
  "version": "1.0.0",
  "type": "module",
  "description": "Vantis Mail - Profesjonalny, bezpieczny system pocztowy zbudowany zgodnie z normami wojskowymi i wywiadowczymi (Zero Trust)",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint &quot;**/*.{js,ts,tsx,jsx,ts,tsx}&quot;",
    "lint:fix": "eslint &quot;**/*.{js,ts,tsx,jsx,ts,tsx}&quot; --fix",
    "format": "prettier --write &quot;**/*.{js,ts,tsx,css,html,json,md}&quot;",
    "format:check": "prettier --check &quot;**/*.{js,ts,tsx,css,html,json,md}&quot;",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
  "keywords": [
    "email",
    "security",
    "encryption",
    "zero-trust",
    "cryptography",
    "privacy",
    "webmail",
    "quantum-resistant",
    "nsa-cnsa",
    "fips-140-3"
  ],
  "author": "Vantis Development Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.10",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,css,html,json,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
