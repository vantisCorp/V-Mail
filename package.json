{
  "name": "vantis-mail",
  "version": "1.5.0",
  "type": "module",
  "description": "Vantis Mail - Profesjonalny, bezpieczny system pocztowy zbudowany zgodnie z normami wojskowymi i wywiadowczymi (Zero Trust)",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint src tests --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src tests --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write **/*.{js,ts,tsx,css,html,json,md}",
    "format:check": "prettier --check **/*.{js,ts,tsx,css,html,json,md}",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "bundle-report": "npm run build:analyze && npx vite-bundle-visualizer"
  },
  "keywords": [
    "email",
    "security",
    "encryption",
    "zero-trust",
    "cryptography",
    "privacy",
    "webmail",
    "quantum-resistant",
    "nsa-cnsa",
    "fips-140-3"
  ],
  "author": "Vantis Development Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lunr": "^2.3.7",
    "@types/node": "^20.19.35",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.10",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx,css,html,json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "lunr": "^2.3.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "speakeasy": "^2.0.0"
  }
}
