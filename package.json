{
  "name": "vantis-mail",
  "version": "1.0.0",
  "description": "Vantis Mail - Profesjonalny, bezpieczny system pocztowy zbudowany zgodnie z normami wojskowymi i wywiadowczymi (Zero Trust)",
  "main": "index.html",
  "scripts": {
    "dev": "python -m http.server 8000",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "format": "prettier --write &quot;**/*.{js,css,html,json,md}&quot;",
    "format:check": "prettier --check &quot;**/*.{js,css,html,json,md}&quot;",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "build": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "keywords": [
    "email",
    "security",
    "encryption",
    "zero-trust",
    "cryptography",
    "privacy",
    "webmail",
    "quantum-resistant",
    "nsa-cnsa",
    "fips-140-3"
  ],
  "author": "Vantis Development Team",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.10",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,css,html,json,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  }
}
