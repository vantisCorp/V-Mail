{
  "name": "vantis-mail-mobile",
  "version": "1.0.0",
  "description": "Vantis Mail - Secure email system with military-grade encryption (Mobile Application)",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,css,html,json,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,js,jsx,css,html,json,md}",
    "clean": "react-native clean",
    "android:build": "cd android && ./gradlew assembleRelease && cd ..",
    "ios:build": "cd ios && xcodebuild -workspace VantisMail.xcworkspace -scheme VantisMail -configuration Release && cd .."
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.3",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/stack": "^7.8.2",
    "react": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-background-timer": "^2.4.1",
    "react-native-biometrics": "^3.0.1",
    "react-native-document-picker": "^9.3.1",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fast-image": "^8.6.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-keychain": "^10.0.0",
    "react-native-local-authentication": "^0.1.1",
    "react-native-mmkv": "^4.1.2",
    "react-native-permissions": "^5.5.0",
    "react-native-quick-crypto": "^1.0.15",
    "react-native-quick-sqlite": "^8.2.7",
    "react-native-randombytes": "^3.6.2",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-secure-key-store": "^2.0.10",
    "react-native-sensitive-info": "^5.6.2",
    "react-native-share": "^12.2.5",
    "react-native-tcp": "^4.0.0",
    "react-native-udp": "^4.1.7",
    "react-native-vector-icons": "^10.3.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "@types/react-native-document-picker": "^3.1.0",
    "@types/react-native-fs": "^2.8.3",
    "@types/react-native-keychain": "^3.0.0",
    "@types/react-native-permissions": "^1.1.1",
    "@types/react-native-share": "^3.3.8",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-navigation": "^3.0.8",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}